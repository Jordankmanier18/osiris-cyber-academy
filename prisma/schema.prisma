generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(cuid())
  name          String?
  email         String?  @unique
  currentRoleId String?
  totalXp       Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  currentRole Role?          @relation(fields: [currentRoleId], references: [id])
  submissions Submission[]
  progress    UserProgress[]
}

model Role {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  level         Int      @unique
  description   String
  framework     String?
  certification String?
  xpRequired    Int      @default(0)
  nextRoleSlug  String?
  createdAt     DateTime @default(now())

  users    User[]
  missions Mission[]
  lessons  Lesson[]
  labs     Lab[]
  tickets  Ticket[]
}

model Lesson {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String
  content     String
  roleId      String
  difficulty  String
  xpReward    Int      @default(10)
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  role     Role           @relation(fields: [roleId], references: [id])
  progress UserProgress[]
}

model Mission {
  id             String   @id @default(cuid())
  title          String
  slug           String   @unique
  description    String
  scenario       String
  difficulty     String
  roleId         String
  category       String
  xpReward       Int      @default(25)
  expectedAnswer String?
  createdAt      DateTime @default(now())

  role        Role         @relation(fields: [roleId], references: [id])
  submissions Submission[]
}

model Lab {
  id           String   @id @default(cuid())
  title        String
  slug         String   @unique
  description  String
  labType      String
  roleId       String
  difficulty   String
  xpReward     Int      @default(20)
  instructions String
  createdAt    DateTime @default(now())

  role     Role           @relation(fields: [roleId], references: [id])
  progress UserProgress[]
}

model Ticket {
  id             String   @id @default(cuid())
  title          String
  ticketCode     String   @unique
  priority       String
  scenario       String
  evidence       String
  requiredAction String
  roleId         String
  difficulty     String
  xpReward       Int      @default(15)
  createdAt      DateTime @default(now())

  role     Role           @relation(fields: [roleId], references: [id])
  progress UserProgress[]
}

model Submission {
  id        String   @id @default(cuid())
  answer    String
  score     Int?
  feedback  String?
  missionId String
  userId    String?
  createdAt DateTime @default(now())

  mission Mission @relation(fields: [missionId], references: [id])
  user    User?   @relation(fields: [userId], references: [id])
}

model UserProgress {
  id          String    @id @default(cuid())
  userId      String
  lessonId    String?
  labId       String?
  ticketId    String?
  status      String    @default("not_started")
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  user   User    @relation(fields: [userId], references: [id])
  lesson Lesson? @relation(fields: [lessonId], references: [id])
  lab    Lab?    @relation(fields: [labId], references: [id])
  ticket Ticket? @relation(fields: [ticketId], references: [id])
}
