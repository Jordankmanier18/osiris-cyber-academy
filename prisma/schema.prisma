generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  name         String?
  email        String   @unique
  passwordHash String?
  points       Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  roleId String?
  role   Role?   @relation(fields: [roleId], references: [id])

  submissions Submission[]
  progress    UserProgress[]
}

model Role {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  level         Int      @unique
  description   String
  framework     String?
  certification String?
  xpRequired    Int      @default(0)
  nextRoleSlug  String?
  createdAt     DateTime @default(now())

  users    User[]
  courses  Course[]
  missions Mission[]
  lessons  Lesson[]
  labs     Lab[]
  tickets  Ticket[]
}

model Course {
  id             String   @id @default(cuid())
  title          String
  slug           String   @unique
  description    String
  certification  String?
  roleId         String
  difficulty     String   @default("beginner")
  estimatedHours Int?
  order          Int      @default(0)
  isPublished    Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  role    Role     @relation(fields: [roleId], references: [id])
  modules Module[]

  @@unique([roleId, order])
}

model Module {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String
  courseId    String
  order       Int      @default(0)
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course  Course   @relation(fields: [courseId], references: [id])
  lessons Lesson[]

  @@unique([courseId, order])
}

model Lesson {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String
  content     String
  roleId      String
  moduleId    String?
  difficulty  String
  xpReward    Int      @default(10)
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  role          Role           @relation(fields: [roleId], references: [id])
  module        Module?        @relation(fields: [moduleId], references: [id])
  progress      UserProgress[]
  quizQuestions QuizQuestion[]
}

model QuizQuestion {
  id          String   @id @default(cuid())
  lessonId    String
  question    String
  explanation String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  lesson  Lesson       @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  choices QuizChoice[]
}

model QuizChoice {
  id         String  @id @default(cuid())
  questionId String
  text       String
  isCorrect  Boolean @default(false)
  order      Int     @default(0)

  question QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model Mission {
  id             String   @id @default(cuid())
  title          String
  slug           String   @unique
  description    String
  scenario       String
  difficulty     String
  roleId         String
  category       String
  xpReward       Int      @default(25)
  expectedAnswer String?
  createdAt      DateTime @default(now())

  role        Role         @relation(fields: [roleId], references: [id])
  submissions Submission[]
}

model Lab {
  id           String   @id @default(cuid())
  title        String
  slug         String   @unique
  description  String
  labType      String
  roleId       String
  difficulty   String
  xpReward     Int      @default(20)
  instructions String
  createdAt    DateTime @default(now())

  role     Role           @relation(fields: [roleId], references: [id])
  progress UserProgress[]
}

model Ticket {
  id             String   @id @default(cuid())
  title          String
  ticketCode     String   @unique
  priority       String
  scenario       String
  evidence       String
  requiredAction String
  roleId         String
  difficulty     String
  xpReward       Int      @default(15)
  createdAt      DateTime @default(now())

  role     Role           @relation(fields: [roleId], references: [id])
  progress UserProgress[]
}

model Submission {
  id        String   @id @default(cuid())
  answer    String
  score     Int?
  feedback  String?
  missionId String
  userId    String?
  createdAt DateTime @default(now())

  mission Mission @relation(fields: [missionId], references: [id])
  user    User?   @relation(fields: [userId], references: [id])
}

model UserProgress {
  id          String    @id @default(cuid())
  userId      String
  lessonId    String?
  labId       String?
  ticketId    String?
  status      String    @default("not_started")
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  user   User    @relation(fields: [userId], references: [id])
  lesson Lesson? @relation(fields: [lessonId], references: [id])
  lab    Lab?    @relation(fields: [labId], references: [id])
  ticket Ticket? @relation(fields: [ticketId], references: [id])
}
